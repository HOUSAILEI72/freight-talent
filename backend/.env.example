# 把此文件复制为 .env 并填写真实值，切勿将 .env 提交到版本库。
# cp .env.example .env

# ── 数据库 ────────────────────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=your_mysql_password
# 必须用 127.0.0.1，Windows 下 PyMySQL + localhost 会触发 DNS 解析超时
# Docker Compose 内部使用 DB_HOST=db（通过 environment: 注入，不依赖此文件）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=freight_talent

# ── JWT ───────────────────────────────────────────────────────────────────────
# 生产用：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_32_CHAR_HEX
# access token 有效期（分钟，生产建议 15）
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
# refresh token 有效期（天）
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_APP=run.py
# development | production
FLASK_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
# 本地快速启动：docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://127.0.0.1:6379/0

# 限流存储（与 REDIS_URL 保持一致；开发无 Redis 时可临时用 memory://）
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# 生产改为实际前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 静态资源托管 ──────────────────────────────────────────────────────────────
# true = Flask 直接托管 ../dist（单机小流量可用）
# false = 独立 Nginx/CDN 托管（推荐生产）
SERVE_STATIC=false

# ── 日志 ──────────────────────────────────────────────────────────────────────
# 级别: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
# 滚动文件目录，相对 backend/，默认 backend/logs
LOG_DIR=logs
# false 时只输出到 stdout（容器/k8s 推荐）；true 时同时写文件
LOG_TO_FILE=true
# 单文件最大字节，默认 10MB
LOG_MAX_BYTES=10485760
# 滚动保留份数
LOG_BACKUP_COUNT=5

# ── 邮件 ──────────────────────────────────────────────────────────────────────
# 是否启用邮件发送（本地开发可设为 false 避免误发）
MAIL_ENABLED=true
# SMTP 服务器（腾讯企业邮箱）
MAIL_HOST=smtp.exmail.qq.com
MAIL_PORT=465
MAIL_USE_SSL=true
# 发件邮箱账号
MAIL_USERNAME=ace_talent@globalogin.com
# SMTP 授权码（不要用登录密码，使用腾讯企业邮箱后台生成的授权码）
# 生产环境填写真实授权码，切勿提交到版本库
MAIL_PASSWORD=your_smtp_authorization_code
# 发件人显示名称
MAIL_DEFAULT_SENDER=ACE-Talent <ace_talent@globalogin.com>
# 网站公开 URL
PUBLIC_SITE_URL=https://globalogin.com
