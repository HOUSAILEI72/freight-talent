# 把此文件复制为 .env 并填写真实值，切勿将 .env 提交到版本库。
# cp .env.example .env

# ── 数据库 ────────────────────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=freight_talent

# ── JWT ───────────────────────────────────────────────────────────────────────
# 生产用：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_32_CHAR_HEX
# access token 有效期（分钟，生产建议 15）
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
# refresh token 有效期（天）
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_APP=run.py
# development | production
FLASK_ENV=development

# ── 限流存储 ──────────────────────────────────────────────────────────────────
# 开发：memory://
# 生产：redis://localhost:6379/0  （生产必须设置，否则 ProductionConfig 报错）
RATELIMIT_STORAGE_URI=memory://

# ── CORS ──────────────────────────────────────────────────────────────────────
# 生产改为实际前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 静态资源托管 ──────────────────────────────────────────────────────────────
# true = Flask 直接托管 ../dist（单机小流量可用）
# false = 独立 Nginx/CDN 托管（推荐生产）
SERVE_STATIC=false
