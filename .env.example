# FreightTalent — docker-compose 生产环境变量模板
# 使用方式：cp .env.example .env  然后填入真实值
# ⚠️  .env 文件绝不能提交到 Git（已在 .gitignore 中排除）

# ── 数据库 ────────────────────────────────────────────────────────────────────
# docker-compose 内部服务名为 db，容器外部访问用 127.0.0.1
DB_PASSWORD=STRONG_RANDOM_DB_PASSWORD_HERE
DB_NAME=freight_talent

# ── JWT Secret ────────────────────────────────────────────────────────────────
# 生产必须替换：python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_FROM_secrets.token_hex_32
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# 设置为你的生产域名（与 Nginx server_name 一致）
# 多个域名用逗号分隔，如：https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# ── SMTP 邮件（生产邀约邮件）──────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.exmail.qq.com
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USERNAME=ace_talent@globalogin.com
MAIL_PASSWORD=your_smtp_authorization_code
MAIL_DEFAULT_SENDER=ACE-Talent <ace_talent@globalogin.com>
PUBLIC_SITE_URL=https://globalogin.com

# ── Compose 项目名（可选，用于区分多个 compose 栈） ──────────────────────────
COMPOSE_PROJECT_NAME=freight-talent
