# FreightTalent — 生产环境变量模板
# 使用方式：
#   cp .env.example .env
#   nano .env
#
# ⚠️ 注意：
# - .env.example 可以提交到 Git
# - .env 绝对不能提交到 Git
# - 这里不要填写真实密码、真实密钥、真实 Token

# ── Compose 项目名 ────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=freight-talent

# ── Flask / FastAPI 基础环境 ──────────────────────────────────────────────────
FLASK_ENV=production

# ── 数据库：腾讯云轻量数据库 MySQL 8.0 ───────────────────────────────────────
# 生产环境使用腾讯云轻量数据库内网地址，不使用 Docker 内置 MySQL
DB_HOST=10.0.4.9
DB_PORT=3306
DB_USER=freight_app
DB_PASSWORD=REPLACE_WITH_APP_DATABASE_PASSWORD
DB_NAME=freight_talent
# 日常应用运行账号：freight_app
# 数据库迁移账号：freight_migrate
# root 只用于初始化数据库、创建用户、紧急维护，不给应用长期使用
# ── JWT Secret ────────────────────────────────────────────────────────────────
# 生产必须替换：
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_FROM_SECRETS_TOKEN_HEX_32
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ── CORS / 站点地址 ───────────────────────────────────────────────────────────
CORS_ORIGINS=https://globalogin.com,https://www.globalogin.com
PUBLIC_SITE_URL=https://globalogin.com

# ── Redis / 限流存储 ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
RATELIMIT_STORAGE_URI=redis://redis:6379/0
# ── 腾讯云 COS：简历、头像、附件存储 ─────────────────────────────────────────
COS_SECRET_ID=REPLACE_WITH_TENCENT_CLOUD_SECRET_ID
COS_SECRET_KEY=REPLACE_WITH_TENCENT_CLOUD_SECRET_KEY
COS_BUCKET=REPLACE_WITH_COS_BUCKET_NAME
COS_REGION=ap-shanghai
# ── Sentry：后端 / 前端错误监控 ───────────────────────────────────────────────
# 不启用可留空
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# ── SMTP 邮件：生产邀约邮件 ──────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.exmail.qq.com
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USERNAME=ace_talent@globalogin.com
MAIL_PASSWORD=REPLACE_WITH_SMTP_AUTHORIZATION_CODE
MAIL_DEFAULT_SENDER=ACE-Talent <ace_talent@globalogin.com>
